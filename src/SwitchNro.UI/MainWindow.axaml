<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SwitchNro.UI.MainWindow"
        Title="SwitchNro — Switch NRO 模拟器"
        Width="1280" Height="720"
        MinWidth="800" MinHeight="600"
        Background="#1B1B1D"
        WindowStartupLocation="CenterScreen">

    <Panel>
        <DockPanel>
            <!-- 顶部工具栏 -->
            <Border DockPanel.Dock="Top" Height="48" Background="#2D2D2D" BorderBrush="#111111" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="Auto, *, Auto" Margin="12,0" VerticalAlignment="Center">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="🎮 SwitchNro" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Border Width="1" Height="20" Background="#444444" Margin="4,0"/>
                        <TextBlock Text="M1 NATIVE" FontSize="9" Foreground="#4A90E2" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Name="OpenNroButton" Content="📂 打开 NRO" Background="Transparent" Foreground="#CCCCCC" FontSize="12"/>
                        <Button Name="PauseButton" Content="⏸ 暂停" Background="Transparent" Foreground="#CCCCCC" FontSize="12"/>
                        <Button Name="DebugButton" Content="🐛 调试" Background="Transparent" Foreground="#CCCCCC" FontSize="12"/>
                        <Button Name="SettingsButton" Content="⚙️ 设置" Background="Transparent" Foreground="#CCCCCC" FontSize="12"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Name="FpsLabel" Text="FPS: --" FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 底部状态栏 -->
            <Border DockPanel.Dock="Bottom" Height="28" Background="#007ACC" Padding="15,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="20">
                    <TextBlock Name="StatusText" Text="就绪 — 等待加载 NRO 文件" FontSize="11" Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- 主内容区 -->
            <Grid ColumnDefinitions="*, 280">
                <!-- 左侧：游戏渲染区域 -->
                <Border Grid.Column="0" Margin="8" Background="#0A0A0A" CornerRadius="6" BorderBrush="#333333" BorderThickness="1" ClipToBounds="True">
                    <Grid RowDefinitions="*, 80">
                        <!-- Metal 游戏渲染占位 -->
                        <Border Grid.Row="0" Background="#050505">
                            <Panel>
                                <TextBlock Name="PlaceholderText" Text="拖放 NRO 文件到此处开始模拟" 
                                           Foreground="#333333" FontSize="18" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Panel>
                        </Border>
                        <!-- 鹰眼图 -->
                        <Border Grid.Row="1" Background="#111111" BorderBrush="#222222" BorderThickness="0,1,0,0">
                            <TextBlock Text="全景导航" FontSize="10" Foreground="#444444" Margin="8,4"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- 右侧：信息面板 -->
                <Border Grid.Column="1" Margin="0,8,8,8" Background="#252526" CornerRadius="6" BorderBrush="#333333" BorderThickness="1">
                    <TabControl Padding="0">
                        <TabItem Header="进程">
                            <StackPanel Margin="10" Spacing="8">
                                <TextBlock Text="进程信息" FontSize="11" FontWeight="Bold" Foreground="#666666"/>
                                <TextBlock Name="ProcessInfoText" Text="未运行" FontSize="12" Foreground="#AAAAAA"/>
                                <Separator Height="1" Background="#333333"/>
                                <TextBlock Text="寄存器" FontSize="11" FontWeight="Bold" Foreground="#666666"/>
                                <TextBlock Name="RegistersText" Text="PC: 0x00000000" FontSize="11" Foreground="#888888" FontFamily="Courier New"/>
                                <TextBlock Name="SpText" Text="SP: 0x00000000" FontSize="11" Foreground="#888888" FontFamily="Courier New"/>
                            </StackPanel>
                        </TabItem>
                        <TabItem Header="服务">
                            <ListBox Name="ServiceList" Background="Transparent" BorderThickness="0"/>
                        </TabItem>
                        <TabItem Header="SVC 日志">
                            <ListBox Name="SvcLogList" Background="Transparent" BorderThickness="0"/>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </DockPanel>

        <!-- 加载遮罩 -->
        <Border Name="LoadingOverlay" Background="#CC000000" IsVisible="False">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                <ProgressBar IsIndeterminate="True" Width="200" Height="2" Foreground="#4A90E2"/>
                <TextBlock Text="正在加载 NRO 模块..." Foreground="White" FontSize="14"/>
            </StackPanel>
        </Border>
    </Panel>
</Window>
